AGENT_INGEST_TOKEN=replace-with-a-different-long-random-token
# Use an organization Admin key restricted to the Usage read permission.
OPENAI_ADMIN_KEY=sk-admin-replace-with-usage-read-key
OPENAI_USAGE_TIMEZONE=Asia/Taipei
OPENAI_HIGH_POOL_LIMIT=250000
OPENAI_MINI_POOL_LIMIT=2500000
OPENAI_FREE_HIGH_MODELS_JSON=[]
OPENAI_FREE_MINI_MODELS_JSON=["*mini*","*nano*"]
OPENAI_KEY_LABELS_JSON={}
OPENAI_PROJECT_LABELS_JSON={}
# Optional: enables one alert per pool/day at 70%, 85%, and 95%.
DISCORD_WEBHOOK_URL=
# Incident alerts: Discord webhook for service DOWN/RECOVERY notices. Falls back to DISCORD_WEBHOOK_URL if unset.
DISCORD_ALERT_WEBHOOK_URL=
ALERT_FAILURE_THRESHOLD=2
# Certificate and domain expiry warning thresholds.
CERT_WARN_DAYS=21
DOMAIN_WARN_DAYS=30
CERT_CHECK_INTERVAL_HOURS=6
# Generic dead-man's-switch heartbeats. Each job GETs /api/heartbeat/<id>?token=... on its own schedule.
HEARTBEAT_TOKEN=
HEARTBEATS_JSON=[]
# Optional: the dashboard pings this URL after every successful refresh (e.g. a Healthchecks.io check) so an outside service alerts if the dashboard itself dies.
EXTERNAL_HEARTBEAT_URL=
